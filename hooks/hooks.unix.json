{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SHAPEUP_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/phase-guard.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SHAPEUP_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/ripple-check.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${SHAPEUP_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/commit-gate.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
