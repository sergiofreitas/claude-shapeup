{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root=$env:SHAPEUP_PLUGIN_ROOT; if (-not $root) { $root=$env:CLAUDE_PLUGIN_ROOT }; & (Join-Path $root 'hooks/phase-guard.ps1')\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root=$env:SHAPEUP_PLUGIN_ROOT; if (-not $root) { $root=$env:CLAUDE_PLUGIN_ROOT }; & (Join-Path $root 'hooks/ripple-check.ps1')\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root=$env:SHAPEUP_PLUGIN_ROOT; if (-not $root) { $root=$env:CLAUDE_PLUGIN_ROOT }; & (Join-Path $root 'hooks/commit-gate.ps1')\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
