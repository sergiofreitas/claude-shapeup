#!/bin/bash
# post-commit — auto-bump patch version in plugin.json + marketplace.json and
# fold the bump into the commit that just landed.
#
# This used to live in pre-push, but pre-push's `git commit --amend` fires
# AFTER git has already frozen the ref list it's about to push — the amend
# creates a new local SHA that never rides along with the push, leaving the
# remote one commit behind forever. post-commit runs while the commit's SHA
# is still "new" and has not been pushed; amending here updates HEAD before
# any push ever gets planned.
#
# Guard: BUMPING_VERSION=1 short-circuits on the re-entrant commit that the
# amend produces, so we don't recurse forever.
#
# Skip: if the triggering commit ALREADY touched plugin.json's version (e.g.
# a manual minor/major bump for a breaking change), we don't double-bump.

set -uo pipefail

if [ "${BUMPING_VERSION:-0}" = "1" ]; then
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"
MARKETPLACE_JSON="$REPO_ROOT/.claude-plugin/marketplace.json"

if [ ! -f "$PLUGIN_JSON" ]; then
  exit 0
fi

CURRENT=$(grep -oE '"version":\s*"[0-9]+\.[0-9]+\.[0-9]+"' "$PLUGIN_JSON" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')

if [ -z "$CURRENT" ]; then
  echo "post-commit: could not parse version from plugin.json" >&2
  exit 0
fi

# If the triggering commit already changed plugin.json's version line, the
# author did the bump themselves — don't override.
if git show HEAD -- "$PLUGIN_JSON" | grep -qE '^\+\s*"version":\s*"[0-9]+\.[0-9]+\.[0-9]+"'; then
  exit 0
fi

MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PLUGIN_JSON"

if [ -f "$MARKETPLACE_JSON" ]; then
  sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$MARKETPLACE_JSON"
fi

git add "$PLUGIN_JSON" "$MARKETPLACE_JSON" 2>/dev/null
BUMPING_VERSION=1 git commit --amend --no-edit --no-verify >/dev/null 2>&1

echo "post-commit: version bumped $CURRENT → $NEW_VERSION" >&2

exit 0
