#!/bin/bash
# pre-push — run the behavioral suite as an outcome gate before allowing a push
# that touches prompts / hooks / references / shared scripts.
#
# Version auto-bump used to live here and amend the top commit after the push
# plan was already frozen, which left the amend local-only. The bump has
# moved to .githooks/post-commit, which runs while HEAD can still be safely
# rewritten. This hook is now a pure outcome gate.
#
# Bypass (LLM outage, known-noisy judge runs, genuinely unrelated push):
#   SHAPEUP_SKIP_BEHAVIORAL=1 git push

set -uo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
ZERO_SHA="0000000000000000000000000000000000000000"

touched=""
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_sha" ] && continue
  [ "$local_sha" = "$ZERO_SHA" ] && continue  # branch delete

  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    base=$(git merge-base "$local_sha" "origin/HEAD" 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      range="$base..$local_sha"
    else
      range="$local_sha"
    fi
  else
    range="$remote_sha..$local_sha"
  fi

  changed=$(git diff --name-only "$range" 2>/dev/null \
    | grep -E '^(skills/[^/]+/SKILL\.md|skills/.+/scripts/.+|hooks/.+|references/.+)$' \
    || true)
  [ -n "$changed" ] && touched="$touched$changed"$'\n'
done

if [ -z "$touched" ]; then
  exit 0
fi

if [ "${SHAPEUP_SKIP_BEHAVIORAL:-0}" = "1" ]; then
  echo "pre-push: SHAPEUP_SKIP_BEHAVIORAL=1 — skipping behavioral gate." >&2
  exit 0
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "pre-push: prompts/scripts changed but claude CLI not installed — behavioral gate skipped." >&2
  echo "         Install claude or run bash tests/run-all.sh --behavioral before pushing." >&2
  exit 0
fi

echo "pre-push: prompts/scripts changed — running behavioral suite (this takes a few minutes)..." >&2
if ! bash "$REPO_ROOT/tests/run-all.sh" --behavioral; then
  cat >&2 <<EOF

pre-push: behavioral suite failed. Push blocked.

Behavioral tests check agent OUTCOMES via LLM-as-judge against rubric-based
scenarios. A failure here usually means one of three things:

  (a) A prompt edit moved agent behavior off-contract — fix the prompt.
  (b) The rubric/criteria now under-specify what "correct" looks like —
      extend tests/behavioral/criteria/ or judge-rubric.md.
  (c) The scenario needs tightening because it's ambiguous to the agent.

If you have a justified reason to bypass (LLM outage, known-noisy judge run,
genuinely unrelated push): SHAPEUP_SKIP_BEHAVIORAL=1 git push
EOF
  exit 1
fi

echo "pre-push: behavioral suite passed." >&2
exit 0
